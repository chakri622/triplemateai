# Virtual environments (never ship the host venv)
.venv/
venv/
env/
ENV/

# Secrets — must NOT be baked into the image
.env
.env.*

# Version control & CI
.git/
.gitignore
.github/

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db

# Project-local tooling & docs not needed at runtime
.claude/
*.md
test.py
uv.lock
